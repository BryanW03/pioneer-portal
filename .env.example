# ============================================
# PIONEER PORTAL - ENVIRONMENT VARIABLES
# ============================================
# Copia este archivo como .env.local y completa los valores

# --- NEXTAUTH ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production

# --- MICROSOFT AZURE AD ---
# Registra tu app en: https://portal.azure.com → Azure Active Directory → App Registrations
# Redirect URI: http://localhost:3000/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=your-azure-client-id
AZURE_AD_CLIENT_SECRET=your-azure-client-secret
AZURE_AD_TENANT_ID=your-azure-tenant-id

# --- DATABASE ---
DATABASE_URL="file:./dev.db"

# --- ADMIN ---
# Email del administrador principal (no cambiar)
ADMIN_EMAIL=b.deleon@pioneerfunds.do
